# ─── PropOS API — environment ─────────────────────────────────────────
DATABASE_URL=              # Neon Postgres connection string (?sslmode=require)
PORT=3001
FRONTEND_URL=              # deployed web URL, e.g. https://propos.vercel.app

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# AI (optional)
OPENAI_API_KEY=

# Broker token encryption (32+ random chars)
BROKER_TOKEN_ENCRYPTION_KEY=

# cTrader live sync
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_REDIRECT_URI=      # https://<api-domain>/v1/broker-connections/ctrader/callback

# Tradovate live sync (parked)
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=
TRADOVATE_REDIRECT_URI=
